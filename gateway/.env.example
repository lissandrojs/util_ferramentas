# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/saas_platform

# ─── Redis (Rate limiting & Sessions) ────────────────
REDIS_URL=redis://localhost:6379

# ─── Upstream Services (Apps) ────────────────────────
APP1_DASHBOARD_URL=http://localhost:5173
APP2_URLSHORTENER_URL=http://localhost:4001

# ─── Security ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Stripe (Monetization) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_FREE_PRICE_ID=price_free
STRIPE_PRO_PRICE_ID=price_pro_monthly

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info

# ─── PIX — Chave estática (obrigatório para qualquer modo) ────
# Pode ser email, CPF, telefone ou chave aleatória PIX
PIX_KEY=seu@email.com
PIX_MERCHANT_NAME=NOME DA EMPRESA
PIX_MERCHANT_CITY=SAO PAULO

# ─── PIX Gateway — Asaas (opcional — automatiza confirmação) ──
# Sem ASAAS_API_KEY, o sistema usa PIX estático (confirmação manual)
# Crie conta grátis em: https://www.asaas.com
ASAAS_API_KEY=
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_TOKEN=

# ─── PIX Gateway — EFI Pay (alternativa ao Asaas) ─────────────
EFIPAY_CLIENT_ID=
EFIPAY_CLIENT_SECRET=
EFIPAY_SANDBOX=true

# ─── App3 — Gerenciador de Dados ──────────────────────────────
APP3_DATAMANAGER_URL=http://localhost:4002
